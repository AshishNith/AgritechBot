{
  "expo": {
    "name": "Anaaj AI",
    "slug": "anaaj-ai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#10241b"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow Anaaj AI to use your location to suggest relevant farming information."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#10241b"
      },
      "package": "com.anaajai.mobile",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-av",
      "expo-asset",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Anaaj AI to use your location to suggest relevant farming information.",
          "locationWhenInUsePermission": "Allow Anaaj AI to use your location.",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://10.24.86.198:4000"
    }
  }
}
