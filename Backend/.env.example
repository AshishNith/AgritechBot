# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# MongoDB
MONGODB_URI=mongodb://localhost:27017/anaaj-ai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-1.5-flash

# Sarvam AI (Voice)
SARVAM_API_KEY=your-sarvam-api-key
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text-translate
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech

# ChromaDB (Vector DB)
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=agri_knowledge

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Cache TTL (seconds)
CACHE_TTL=3600

# Queue (increase for higher concurrency, ensure Redis can handle it)
# Recommended: 10 for dev, 25-50 for production, 100+ for dedicated worker instances
QUEUE_CONCURRENCY=25

# Cluster mode (0 = auto-detect CPU cores, N = force N workers)
CLUSTER_WORKERS=0

# OTP (for dev, use static OTP)
OTP_EXPIRY_MINUTES=5
