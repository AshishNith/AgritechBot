# Anaaj AI Backend environment example
# Copy this file to .env and fill in the values for your environment.

# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# MongoDB
MONGODB_URI=mongodb://localhost:27017/anaaj-ai
MONGODB_MAX_POOL_SIZE=50

# Redis
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# AI providers
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Voice
SARVAM_API_KEY=
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text-translate
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech
SARVAM_STT_MODEL=saaras:v2.5
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=anushka

# Vector DB
RAG_ENABLED=true
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=agri_knowledge

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Cache and queues
CACHE_TTL=3600
QUEUE_CONCURRENCY=10
CLUSTER_WORKERS=0

# OTP and demo/test data
OTP_EXPIRY_MINUTES=5
OTP_PREVIEW_ENABLED=false
NOTIFICATION_SEEDING_ENABLED=false

# Payments
PAYMENTS_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PUBLIC_WEBSITE_URL=

# Production-specific
CORS_ORIGINS=
LOG_LEVEL=

# Weather Integration
OPENWEATHER_API_KEY=
