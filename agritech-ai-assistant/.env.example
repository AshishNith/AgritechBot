# --- Backend environment variables ---
# Get from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get from Sarvam AI: https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# Comma-separated list of allowed frontend origins (no trailing slash)
# e.g. https://anaaj-ai.vercel.app,https://www.anaaj.ai
ALLOWED_ORIGINS=http://localhost:5173

# Port (Render sets this automatically)
PORT=3000
